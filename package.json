{
  "name": "llama-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @llama-manager/core --filter @llama-manager/anthropic-openai-bridge build && pnpm --parallel --filter @llama-manager/api --filter @llama-manager/web dev",
    "update:run": "git pull --ff-only && pnpm install && pnpm serve",
    "build": "pnpm -r build",
    "start": "node apps/api/dist/index.js",
    "serve": "pnpm build && pnpm start",
    "auth:hash": "pnpm --filter @llama-manager/api run auth:hash",
    "check": "pnpm check:events && pnpm --filter @llama-manager/core --filter @llama-manager/anthropic-openai-bridge build && pnpm -r check",
    "check:events": "node scripts/check-react-event-captures.mjs",
    "knip": "knip",
    "memory:calibrate": "node scripts/memory-estimate-calibrate.mjs",
    "format": "prettier --write .",
    "browse": "node --experimental-strip-types --no-warnings scripts/browse.ts"
  },
  "devDependencies": {
    "knip": "^6.16.1",
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  }
}
