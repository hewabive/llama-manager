# llama-manager runtime configuration.
# Copy to .env (gitignored) and fill in the values you need.
# Real environment variables set at launch take precedence over this file.

# --- Network ---
# Bind address. 127.0.0.1 = local only; 0.0.0.0 = reachable over the LAN.
# When exposing over the LAN, set an admin password below.
LLAMA_MANAGER_HOST=127.0.0.1
LLAMA_MANAGER_PORT=8787

# --- Admin auth ---
# Admin routes (/api/*) are open when no password is set below.
# Recommended: generate a hash + secret with `pnpm auth:hash 'your-password'`
# and paste its two lines here (the pair below mirrors that output).
LLAMA_MANAGER_ADMIN_PASSWORD_HASH=
LLAMA_MANAGER_AUTH_SECRET=

# Alternative for dev: a plaintext password instead of the hash above.
# If set, AUTH_SECRET defaults to this value when left empty.
LLAMA_MANAGER_ADMIN_PASSWORD=

# Set to true only when serving over HTTPS, otherwise the browser drops the cookie.
# LLAMA_MANAGER_SECURE_COOKIE=false

# Session lifetime in seconds (default 12h).
# LLAMA_MANAGER_SESSION_TTL_SECONDS=43200
