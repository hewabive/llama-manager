{
  "name": "llama-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @llama-manager/core build && pnpm --parallel --filter @llama-manager/api --filter @llama-manager/web dev",
    "update:run": "git pull --ff-only && pnpm install && pnpm dev",
    "build": "pnpm -r build",
    "check": "pnpm check:events && pnpm --filter @llama-manager/core build && pnpm -r check",
    "check:events": "node scripts/check-react-event-captures.mjs",
    "format": "prettier --write .",
    "browse": "node --experimental-strip-types --no-warnings scripts/browse.ts"
  },
  "devDependencies": {
    "playwright": "^1.58.2",
    "prettier": "^3.5.3",
    "typescript": "^5.9.3"
  }
}
